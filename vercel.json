{
  "buildCommand": "pnpm --filter @workspace/healthy-plate run build",
  "outputDirectory": "artifacts/healthy-plate/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "rewrites": [
    { "source": "/admin-api/:path*", "destination": "/api/admin-users" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
